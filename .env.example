# 複製此檔為 .env 並填入你的帳號資訊

# 帳號（email）與密碼（兩種登入方式都需要）
X_USERNAME=your_email@example.com
X_PASSWORD=your_password

# X 使用者名稱（@後面的部分），僅 LOGIN_METHOD=x 且遇到異常驗證時使用
X_HANDLE=your_x_username

# 登入方式：
#   x     → 透過 X (Twitter) 帳號登入（原流程，grok → accounts.x.ai → x.com）
#   email → 直接在 accounts.x.ai 使用 email 登入，不跳轉至 x.com
LOGIN_METHOD=x
